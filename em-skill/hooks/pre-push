#!/bin/bash
#
# EM-Skill Pre-Push Hook
# Source: agent-skills + GSD quality gates
#
# Runs before push to ensure everything is ready
#

set -e

echo "🚀 EM-Skill Pre-Push Checks"
echo "=============================="

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check if we're pushing to main/master
REMOTE="$1"
URL="$2"

echo "📤 Pushing to: $REMOTE"
echo ""

# 1. Full Test Suite
if command_exists npm && npm run test:ci >/dev/null 2>&1; then
    echo "🧪 Running full test suite..."
    if npm run test:ci; then
        echo -e "${GREEN}✓ All tests passed${NC}"
    else
        echo -e "${RED}✗ Tests failed${NC}"
        echo "   Please fix failing tests before pushing"
        exit 1
    fi
    echo ""
elif command_exists npm && npm run test >/dev/null 2>&1; then
    echo "🧪 Running full test suite..."
    if npm run test; then
        echo -e "${GREEN}✓ All tests passed${NC}"
    else
        echo -e "${RED}✗ Tests failed${NC}"
        exit 1
    fi
    echo ""
fi

# 2. Build Check
if command_exists npm && npm run build >/dev/null 2>&1; then
    echo "🔨 Checking build..."
    if npm run build; then
        echo -e "${GREEN}✓ Build successful${NC}"
    else
        echo -e "${RED}✗ Build failed${NC}"
        echo "   Please fix build errors before pushing"
        exit 1
    fi
    echo ""
fi

# 3. Security Audit (if available)
if command_exists npm && npm run audit:ci >/dev/null 2>&1; then
    echo "🔒 Running security audit..."
    if npm run audit:ci; then
        echo -e "${GREEN}✓ Security audit passed${NC}"
    else
        echo -e "${YELLOW}⚠ Security vulnerabilities found${NC}"
        echo "   Review with: npm audit"
        read -p "   Continue anyway? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
    echo ""
elif command_exists npm; then
    echo "🔒 Checking for vulnerabilities..."
    if npm audit --production --audit-level high >/dev/null 2>&1; then
        echo -e "${GREEN}✓ No high/critical vulnerabilities${NC}"
    else
        echo -e "${YELLOW}⚠ Security vulnerabilities found${NC}"
        echo "   Run: npm audit"
    fi
    echo ""
fi

# 4. Check for uncommitted changes
if [ -n "$(git status --porcelain)" ]; then
    echo -e "${YELLOW}⚠ Uncommitted changes detected${NC}"
    echo "   Please commit or stash changes before pushing"
    git status --short
    exit 1
fi

# 5. Check branch protection (warn if pushing to main)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
PROTECTED_BRANCHES="^(main|master|develop|staging)$"

if [[ $CURRENT_BRANCH =~ $PROTECTED_BRANCHES ]]; then
    echo -e "${YELLOW}⚠ Warning: Pushing to protected branch: $CURRENT_BRANCH${NC}"
    echo "   Consider using pull requests instead"
    echo ""
    read -p "   Continue anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# 6. Check commit count
COMMITS_TO_PUSH=$(git log @{u}..HEAD --oneline | wc -l)
if [ "$COMMITS_TO_PUSH" -eq 0 ]; then
    echo "ℹ️  No commits to push"
    exit 0
fi

echo "📊 Pushing $COMMITS_TO_PUSH commit(s):"
git log @{u}..HEAD --oneline | sed 's/^/  - /'
echo ""

# 7. Warn about force push
if git config --get-regexp "push\..*\.force" >/dev/null 2>&1; then
    echo -e "${YELLOW}⚠ Warning: Force push configured${NC}"
    echo "   Be careful with force pushes"
fi

echo ""
echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
echo "   Ready to push $COMMITS_TO_PUSH commit(s)"
