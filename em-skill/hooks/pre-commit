#!/bin/bash
#
# EM-Skill Pre-Commit Hook
# Source: agent-skills + GSD best practices
#
# Runs before each commit to ensure code quality
#

set -e

echo "🔍 EM-Skill Pre-Commit Checks"
echo "=============================="

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check for staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|py|go|rs)$' || true)
if [ -z "$STAGED_FILES" ]; then
    echo "ℹ️  No code files staged, skipping checks"
    exit 0
fi

echo "📝 Staged files:"
echo "$STAGED_FILES" | sed 's/^/  - /'
echo ""

# 1. Type Check (if available)
if command_exists tsc && [ -f "tsconfig.json" ]; then
    echo "🔎 Running TypeScript type check..."
    if tsc --noEmit; then
        echo -e "${GREEN}✓ Type check passed${NC}"
    else
        echo -e "${RED}✗ Type check failed${NC}"
        echo "   Please fix type errors before committing"
        exit 1
    fi
    echo ""
fi

# 2. Lint (if available)
if command_exists npm && npm run lint:check >/dev/null 2>&1; then
    echo "🔎 Running linter..."
    if npm run lint:check; then
        echo -e "${GREEN}✓ Lint check passed${NC}"
    else
        echo -e "${YELLOW}⚠ Lint issues found${NC}"
        echo "   Run 'npm run lint:fix' to auto-fix"
        read -p "   Continue anyway? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
    echo ""
elif command_exists npm && npm run lint >/dev/null 2>&1; then
    echo "🔎 Running linter..."
    if npm run lint; then
        echo -e "${GREEN}✓ Lint check passed${NC}"
    else
        echo -e "${YELLOW}⚠ Lint issues found${NC}"
        exit 1
    fi
    echo ""
fi

# 3. Unit Tests (if available)
if command_exists npm && npm run test:unit >/dev/null 2>&1; then
    echo "🧪 Running unit tests..."
    if npm run test:unit -- --passWithNoTests; then
        echo -e "${GREEN}✓ Unit tests passed${NC}"
    else
        echo -e "${RED}✗ Unit tests failed${NC}"
        echo "   Please fix failing tests before committing"
        echo "   TDD Iron Law: NO PRODUCTION CODE WITHOUT FAILING TEST"
        exit 1
    fi
    echo ""
elif command_exists npm && npm run test >/dev/null 2>&1; then
    echo "🧪 Running tests..."
    if npm run test -- --passWithNoTests; then
        echo -e "${GREEN}✓ Tests passed${NC}"
    else
        echo -e "${RED}✗ Tests failed${NC}"
        exit 1
    fi
    echo ""
fi

# 4. Check for common issues
echo "🔎 Checking for common issues..."

# Check for console.log in committed files
if git diff --cached --name-only | xargs grep -l "console.log" 2>/dev/null | grep -q .; then
    echo -e "${YELLOW}⚠ Warning: console.log found in committed files${NC}"
    echo "   Consider removing debug logs before committing"
fi

# Check for TODO/FIXME without issue reference
TODO_COUNT=$(git diff --cached --name-only | xargs grep -E "TODO|FIXME" 2>/dev/null | grep -vE "TODO:.*#[0-9]+" | wc -l)
if [ "$TODO_COUNT" -gt 0 ]; then
    echo -e "${YELLOW}⚠ Warning: $TODO_COUNT TODO/FIXME without issue reference${NC}"
    echo "   Consider creating issues for tracking"
fi

# Check for large files (>500KB)
LARGE_FILES=$(git diff --cached --name-only | while read file; do
    if [ -f "$file" ]; then
        SIZE=$(du -k "$file" | cut -f1)
        if [ "$SIZE" -gt 500 ]; then
            echo "$file ($(du -h "$file" | cut -f1))"
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠ Warning: Large files detected${NC}"
    echo "$LARGE_FILES" | sed 's/^/   - /'
    echo "   Consider using Git LFS for large files"
fi

echo ""
echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
echo "   Ready to commit with atomic commit message"
