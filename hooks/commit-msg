#!/bin/bash
#
# EM-Skill Commit Message Hook
# Source: GSD + agent-skills best practices
#
# Validates commit messages follow Conventional Commits
#

set -e

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

echo "📝 Validating commit message..."
echo "=============================="

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Conventional Commits pattern
# Format: type(scope): subject
PATTERN="^(feat|fix|refactor|test|docs|chore|style|perf|ci|build|revert)(\(.+\))?: .{1,72}"

# Check if message matches pattern
if [[ ! $COMMIT_MSG =~ $PATTERN ]]; then
    echo -e "${RED}✗ Invalid commit message format${NC}"
    echo ""
    echo "Commit message must follow Conventional Commits format:"
    echo "  <type>(<scope>): <subject>"
    echo ""
    echo "Types:"
    echo "  feat     - New feature"
    echo "  fix      - Bug fix"
    echo "  refactor - Refactoring code"
    echo "  test     - Adding or updating tests"
    echo "  docs     - Documentation changes"
    echo "  chore    - Maintenance tasks"
    echo "  style    - Code style changes (formatting)"
    echo "  perf     - Performance improvements"
    echo "  ci       - CI/CD changes"
    echo "  build    - Build system changes"
    echo "  revert   - Revert a previous commit"
    echo ""
    echo "Examples:"
    echo "  feat(auth): add Google OAuth login"
    echo "  fix(api): resolve race condition in user creation"
    echo "  test(user): add tests for password validation"
    echo "  docs(readme): update installation instructions"
    echo ""
    echo "Rules:"
    echo "  - Subject must be 1-72 characters"
    echo "  - Use imperative mood (\"add\" not \"added\" or \"adds\")"
    echo "  - Do not end with period"
    echo "  - Reference issues in body: \"Closes #123\""
    echo ""
    echo "Your message:"
    echo "  $COMMIT_MSG"
    echo ""
    read -p "Continue anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# Check for issue reference in body (optional but recommended)
if ! grep -qE "#[0-9]+" "$COMMIT_MSG_FILE"; then
    echo -e "${YELLOW}⚠ No issue reference found${NC}"
    echo "   Consider adding issue reference: \"Closes #123\""
fi

# Check subject line length
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo -e "${YELLOW}⚠ Subject line exceeds 72 characters${NC}"
    echo "   Current length: ${#FIRST_LINE}"
    echo "   Consider shortening the subject"
fi

# Check for empty body for major changes
TYPE=$(echo "$COMMIT_MSG" | sed -E 's/([a-z]+).*/\1/')
if [[ "$TYPE" == "feat" || "$TYPE" == "fix" ]]; then
    BODY_LINES=$(echo "$COMMIT_MSG" | tail -n +2 | grep -v "^#" | wc -l)
    if [ "$BODY_LINES" -lt 2 ]; then
        echo -e "${YELLOW}⚠ No body provided for $TYPE commit${NC}"
        echo "   Consider adding explanation:"
        echo "   - What was changed?"
        echo "   - Why was it changed?"
        echo "   - References to related issues"
    fi
fi

echo -e "${GREEN}✓ Commit message validated${NC}"
